{
  "name": "YSCPropertyKiosk",
  "version": "1.0.0",
  "scripts": {
    "android": "expo run:android",
    "ios": "expo run:ios",
    "start": "expo start",
    "prebuild": "expo prebuild",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci",
    "web": "expo start --web"
  },
  "dependencies": {
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "expo": "^54.0.0",
    "expo-secure-store": "^55.0.8",
    "expo-status-bar": "~3.0.8",
    "nativewind": "latest",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-heroicons": "^4.0.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.3",
    "react-native-worklets": "0.5.1",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "jest": "^30.1.3",
    "jest-expo": "^54.0.6",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "19.1.0",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "\\.svg$": "<rootDir>/test/__mocks__/svgMock.js",
      "^expo/src/winter$": "<rootDir>/test/__mocks__/emptyMock.js",
      "^expo/src/winter/installGlobal$": "<rootDir>/test/__mocks__/emptyMock.js",
      "^expo/src/winter/runtime\\.native$": "<rootDir>/test/__mocks__/emptyMock.js",
      "^expo/src/winter/(.*)$": "<rootDir>/test/__mocks__/emptyMock.js"
    }
  },
  "main": "node_modules/expo/AppEntry.js",
  "private": true
}
